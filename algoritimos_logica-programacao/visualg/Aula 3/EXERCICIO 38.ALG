Algoritmo "exercicio 38"

Var
   n1,n2,n3,NF:real
   

Inicio
      Escreva("Nota 1:")
      Leia(n1)
      Escreva("Nota 2:")
      Leia(n2)
      Escreva("Nota 3:")
      Leia(n3)
      NF<-((((n3*5)+ n2*3)+ n1*2)/10)
      
      Escreva("A mÈdia Ponderada È de:",NF)
      
Fimalgoritmo